rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserDoc().role == 'admin';
    }

    // ─── Users ───
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
    }

    // ─── Players ───
    match /players/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Nickname index ───
    match /nicknameIndex/{nickname} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Config (app + squad) ───
    match /config/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Games (current week lineups) ───
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Attendance (current week) ───
    match /attendance/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // ─── Missions (Extension writes via REST API) ───
    match /missions/{slot} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Rotations ───
    match /rotations/{rotationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Archive (immutable game history) ───
    match /archive/{archiveId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Stats ───
    match /stats/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Structures (lineup templates) ───
    match /structures/{structId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Web content (public landing page) ───
    match /webContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
