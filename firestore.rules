rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserDoc().role == 'admin';
    }

    function isMember() {
      return isAuthenticated() && getUserDoc().role in ['admin', 'member'];
    }

    function ownsPlayer(playerId) {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/players/$(playerId))
        && get(/databases/$(database)/documents/players/$(playerId)).data.email == getUserDoc().email;
    }

    // ─── Users ───
    match /users/{uid} {
      allow read: if isAuthenticated();
      // Admin can do anything
      allow write: if isAdmin();
      // User can create own doc but role MUST be 'guest'
      allow create: if isAuthenticated() && request.auth.uid == uid
        && request.resource.data.role == 'guest';
      // User can update own doc but CANNOT change role
      allow update: if isAuthenticated() && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // ─── Players ───
    match /players/{playerId} {
      allow read: if isMember();
      allow write: if isAdmin();
      // Member can update profile fields (whitelist) and status (except 'left')
      allow update: if isMember()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['avatar', 'steamUrl', 'telegramUsername', 'telegramId',
                       'discordId', 'discordUsername', 'wishes', 'skills', 'nicknameColor',
                       'status', 'updatedAt'])
        && (request.resource.data.status != 'left' || request.resource.data.status == resource.data.status);
    }

    // ─── Nickname index ───
    match /nicknameIndex/{nickname} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Config (app + squad) ───
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Games (current week lineups) ───
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Slot requests ───
    match /slotRequests/{requestId} {
      allow read: if isAuthenticated();

      allow create: if isAdmin() || (
        isMember()
        && request.resource.data.keys().hasOnly(['gameId', 'playerId', 'slots', 'text', 'createdAt', 'updatedAt'])
        && request.resource.data.gameId is string
        && request.resource.data.playerId is string
        && ownsPlayer(request.resource.data.playerId)
      );

      allow update: if isAdmin() || (
        isMember()
        && ownsPlayer(resource.data.playerId)
        && request.resource.data.playerId == resource.data.playerId
        && request.resource.data.gameId == resource.data.gameId
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['slots', 'text', 'createdAt', 'updatedAt'])
      );

      allow delete: if isAdmin() || (
        isMember()
        && ownsPlayer(resource.data.playerId)
      );
    }

    // ─── Attendance (current week) ───
    match /attendance/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isMember();
    }

    // ─── Missions (Extension writes via REST API, no auth) ───
    match /missions/{slot} {
      allow read: if isAuthenticated();
      allow write: if true;
    }

    // ─── Rotations ───
    match /rotations/{rotationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Archive (immutable game history) ───
    match /archive/{archiveId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Audit logs ───
    match /logs/{logId} {
      allow read: if isAdmin();
      allow write: if isAuthenticated();
    }

    // ─── Stats ───
    match /stats/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Structures (lineup templates) ───
    match /structures/{structId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Web content (public landing page) ───
    match /webContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
