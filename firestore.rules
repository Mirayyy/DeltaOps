rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isAuthenticated() && getUserDoc().role == 'admin';
    }

    function isMember() {
      return isAuthenticated() && getUserDoc().role in ['admin', 'member'];
    }

    // ─── Users ───
    match /users/{uid} {
      allow read: if isAuthenticated();
      // Admin can do anything
      allow write: if isAdmin();
      // User can create own doc but role MUST be 'guest'
      allow create: if isAuthenticated() && request.auth.uid == uid
        && request.resource.data.role == 'guest';
      // User can update own doc but CANNOT change role
      allow update: if isAuthenticated() && request.auth.uid == uid
        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role']);
    }

    // ─── Players ───
    match /players/{playerId} {
      allow read: if isMember();
      allow write: if isAdmin();
      // Member can update profile fields (whitelist) and status (except 'left')
      allow update: if isMember()
        && request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['avatar', 'steamUrl', 'telegramUsername', 'telegramId',
                       'discordId', 'discordUsername', 'wishes', 'skills', 'nicknameColor',
                       'status', 'updatedAt'])
        && (request.resource.data.status != 'left' || request.resource.data.status == resource.data.status);
    }

    // ─── Nickname index ───
    match /nicknameIndex/{nickname} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Config (app + squad) ───
    match /config/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ─── Games (current week lineups) ───
    match /games/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Attendance (current week) ───
    match /attendance/{gameId} {
      allow read: if isAuthenticated();
      allow write: if isMember();
    }

    // ─── Missions (Extension writes via REST API) ───
    match /missions/{slot} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Rotations ───
    match /rotations/{rotationId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Archive (immutable game history) ───
    match /archive/{archiveId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Stats ───
    match /stats/{playerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Structures (lineup templates) ───
    match /structures/{structId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // ─── Web content (public landing page) ───
    match /webContent/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
